# === LLM Provider ===
# Choose: "groq" (free & fast) or "openai"
LLM_PROVIDER=groq

# Groq API Key — free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (optional alternative)
OPENAI_API_KEY=your_openai_api_key_here

# === Model Settings ===
# Groq models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini

# === Browser Settings ===
# Set to "true" to see the browser window (headed mode)
BROWSER_HEADLESS=false

# Browser window size
BROWSER_WIDTH=1280
BROWSER_HEIGHT=800

# Navigation timeout in milliseconds
BROWSER_TIMEOUT=30000

# === Agent Settings ===
# Maximum steps the agent will take per task
MAX_STEPS=15

# Screenshot directory
SCREENSHOT_DIR=screenshots

# === Gradio Settings ===
GRADIO_PORT=7860
GRADIO_SHARE=false
